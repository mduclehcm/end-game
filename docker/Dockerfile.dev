# Stage 0: base Node 24 + pnpm
FROM node:24-bookworm-slim AS base-build
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# Stage 1: monorepo build
FROM base-build AS builder
ARG SERVICE_NAME

RUN apt-get update && apt-get install -y --no-install-recommends curl \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy only manifest files, then install (no source yet)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY services/${SERVICE_NAME}/package.json services/${SERVICE_NAME}/
RUN pnpm install --frozen-lockfile

# Whole service folder is mounted from volume at runtime
ENV PACKAGE_NAME=@algo/${SERVICE_NAME}

WORKDIR /app
CMD ["sh", "-c", "pnpm exec turbo run dev --filter=${PACKAGE_NAME}..."]

