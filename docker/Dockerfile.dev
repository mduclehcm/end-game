# Stage 0: base Node 24 + pnpm
FROM node:24-bookworm-slim AS base-build
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# Stage 1: monorepo build
FROM base-build AS builder
ARG SERVICE_NAME

WORKDIR /app

# Copy only manifest files, then install (no source yet)
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY services/${SERVICE_NAME}/package.json services/${SERVICE_NAME}/
RUN pnpm install --frozen-lockfile

# Copy source and config
COPY services/${SERVICE_NAME}/nest-cli.json services/${SERVICE_NAME}/tsconfig.json services/${SERVICE_NAME}/tsconfig.build.json services/${SERVICE_NAME}/
COPY services/${SERVICE_NAME}/webpack.config.js services/${SERVICE_NAME}/empty-module-loader.js services/${SERVICE_NAME}/
COPY services/${SERVICE_NAME}/src services/${SERVICE_NAME}/src

ENV PACKAGE_NAME=@algo/${SERVICE_NAME}
RUN pnpm exec turbo run dev --filter=${PACKAGE_NAME}...

