# Stage 0: base Node 24 + pnpm
FROM node:24-bookworm-slim AS base-build
RUN corepack enable && corepack prepare pnpm@10.27.0 --activate

# Stage 1: monorepo build
FROM base-build AS builder
ARG SERVICE_NAME

RUN apt-get update && apt-get install -y --no-install-recommends curl \
  && if [ "$SERVICE_NAME" = "resume-service" ]; then \
       apt-get install -y --no-install-recommends chromium; \
     fi \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy only manifest files and workspace packages (for workspace:* resolution), then install
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages/cv-core packages/cv-core
COPY packages/cv-layout packages/cv-layout
COPY services/${SERVICE_NAME}/package.json services/${SERVICE_NAME}/
RUN pnpm install --frozen-lockfile

# Whole service folder is mounted from volume at runtime
ENV PACKAGE_NAME=@algo/${SERVICE_NAME}

WORKDIR /app
CMD ["sh", "-c", "pnpm exec turbo run dev --filter=${PACKAGE_NAME}..."]

