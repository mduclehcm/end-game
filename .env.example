OPENAI_API_KEY=sk-proj-...

# MinIO / PDF export (resume-service). When set, PDF exports use object storage; otherwise stub.
# Docker Compose sets these for resume-service; for local dev with MinIO: use http://localhost:9000
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=algo
# MINIO_SECRET_KEY=algodev8
# MINIO_BUCKET=resume-exports
# MINIO_FORCE_PATH_STYLE=true
# EXPORT_WORKER_ENABLED=true

# Auth service (JWT + OAuth)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_CALLBACK_URL=http://localhost:3001/api/auth/zalo/callback
AUTH_SERVICE_PORT=3001
