{
	"name": "@algo/resume-service",
	"description": "Resume service for the CV application",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "nest build",
		"dev": "nest build --webpack --webpackPath webpack-hrm.config.js --watch",
		"test": "jest --runInBand",
		"test:e2e": "jest --config test/jest-e2e.json --runInBand --forceExit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@algo/cv-core": "workspace:*",
		"@nestjs/common": "^11.0.1",
		"@nestjs/core": "^11.0.1",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/terminus": "^11.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.44.0",
		"multer": "^2.1.1",
		"nanoid": "^5.1.6",
		"openai": "^6.27.0",
		"pdf-parse": "^2.4.5",
		"pg": "^8.18.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.0.0",
		"@types/node": "^22.10.7",
		"@types/supertest": "^6.0.2",
		"drizzle-kit": "^0.31.0",
		"globals": "^16.0.0",
		"jest": "^30.0.0",
		"prettier": "^3.4.2",
		"run-script-webpack-plugin": "^0.2.3",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.7.3",
		"webpack": "^5.105.2",
		"webpack-node-externals": "^3.0.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"moduleNameMapper": {
			"^@domain$": "<rootDir>/domain/index.ts",
			"^@ports$": "<rootDir>/ports/index.ts"
		},
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
