{
	"moduleFileExtensions": ["js", "json", "ts"],
	"rootDir": ".",
	"moduleNameMapper": {
		"^@domain$": "<rootDir>/../src/domain/index.ts",
		"^@ports$": "<rootDir>/../src/ports/index.ts"
	},
	"testEnvironment": "node",
	"testRegex": ".e2e-spec.ts$",
	"transform": {
		"^.+\\.(t|j)s$": "ts-jest"
	}
}
